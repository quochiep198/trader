# TradeMind AI Backend - Local Environment Settings
# WARNING: Do not commit this file with production secrets to Git!

# Connection string for Neon Serverless PostgreSQL or local SQLite
# Local SQLite default: sqlite:///./sql_app.db
# Neon PostgreSQL example: postgresql://[user]:[password]@[neon-host]/[dbname]?sslmode=require
DATABASE_URL=sqlite:///./sql_app.db

# OpenRouter Free AI API configuration
OPENROUTER_API_KEY=dummy_key
OPENROUTER_MODEL=google/gemma-2-9b-it:free
